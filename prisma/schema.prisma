generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SiteStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PlatformRole {
  ADMIN
}

enum ContentLanguage {
  EN
  AR
  DE
  FR
  ES
  IT
  TR
  NL
  FA
}

enum ContentStrategy {
  BUDGET
  BALANCED
  QUALITY
}

enum KeywordIntent {
  INFORMATIONAL
  NAVIGATIONAL
  TRANSACTIONAL
  COMMERCIAL
}

enum KeywordStatus {
  PENDING
  IN_PROGRESS
  PUBLISHED
  FAILED
  SKIPPED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  NEEDS_UPDATE
  ARCHIVED
}

enum TaskStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskType {
  GENERATE_CONTENT
  REWRITE_CONTENT
  GENERATE_META
  GENERATE_SCHEMA
  GENERATE_IMAGE
}

enum AiProvider {
  openai
  anthropic
  google
}

enum AiGenerationStatus {
  SUCCESS
  FAILED
}

enum KeywordResearchSource {
  MANUAL
  AI
  GSC
}

enum PipelineStatus {
  PENDING
  GENERATING
  VALIDATING
  ANALYZING
  GEO_SCORING
  REWRITING
  IMAGE_GENERATING
  SEO_CHECKING
  READY
  FAILED
  PARTIALLY_COMPLETED
  SKIPPED_STEP
}

enum PageKeywordRole {
  PRIMARY
  SECONDARY
}

enum CannibalizationStatus {
  WINNER
  LOSER
  MONITOR
  NONE
}

enum SubjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum IdeaStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum HallucinationSensitivity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskCategory {
  GENERAL
  MEDICAL
  LEGAL
  FINANCIAL
  IMMIGRATION
  PRICING
}

enum ContentType {
  ARTICLE
  LANDING_PAGE
  CITY_PAGE
  FAQ
  COMPARISON
  BLOG_POST
}

enum IdeaTaskStatus {
  QUEUED
  PROCESSING
  GENERATED
  FAILED
  PUBLISHED
}

model Site {
  id                     Int              @id @default(autoincrement())
  name                   String
  domain                 String           @unique
  timezone               String           @default("UTC")
  status                 SiteStatus       @default(ACTIVE)
  config                 Json?

  defaultLanguage        ContentLanguage  @default(EN)
  languages              ContentLanguage[]
  strategy               ContentStrategy  @default(BALANCED)
  gscProperty            String?
  ga4PropertyId           String?
  aiPipeline             Json?

  publishWebhookUrl      String?
  publishWebhookSecret   String?
  autoPublish            Boolean          @default(true)
  contentApiKeyHash      String?
  contentApiKeyCreatedAt DateTime?

  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  keywords               Keyword[]
  pages                  Page[]
  seoMetrics             SeoMetric[]
  siteConfig             SiteConfig?
  promptTemplates        PromptTemplate[]
  costLedger             CostLedger[]
  keywordClusters        KeywordCluster[]
  subjects               Subject[]
  ideaTasks              IdeaTask[]

  @@index([domain])
  @@map("sites")
}

model Keyword {
  id                   Int              @id @default(autoincrement())
  siteId               Int
  keyword              String
  language             ContentLanguage  @default(EN)
  baseKeywordId        Int?
  intent               KeywordIntent    @default(INFORMATIONAL)
  status               KeywordStatus    @default(PENDING)
  searchVolume         Int?
  difficulty           Float?
  cpc                  Float?
  priority             Int              @default(0)
  cannibalizationGroup String?
  targetUrl            String?
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  site            Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  baseKeyword     Keyword?         @relation("KeywordCluster", fields: [baseKeywordId], references: [id], onDelete: SetNull)
  derivedKeywords Keyword[]        @relation("KeywordCluster")
  pages           Page[]
  contentTasks    ContentTask[]
  pageKeywords    PageKeyword[]
  cluster         KeywordCluster?  @relation("ClusterMain")

  @@unique([siteId, keyword, language])
  @@index([siteId, status])
  @@index([siteId, priority])
  @@index([siteId, language])
  @@index([baseKeywordId])
  @@map("keywords")
}

model Page {
  id                   Int                   @id @default(autoincrement())
  siteId               Int
  keywordId            Int
  language             ContentLanguage       @default(EN)
  slug                 String
  title                String?
  metaTitle            String?
  metaDescription      String?
  outline              Json?
  rawDraft             String?               @db.Text
  finalContent         String?               @db.Text
  imagePrompt          String?               @db.Text
  generatedImageBase64 String?               @db.Text
  schemaMarkup         Json?
  status               PageStatus            @default(DRAFT)
  seoScore             Float?
  seoCheckScore        Int?
  seoCheckPassed       Boolean?
  seoCheckIssues       Json?
  geoScore             Float?
  geoScorePillars      Json?
  cannibalizationStatus CannibalizationStatus @default(NONE)
  readabilityScore     Float?
  wordCount            Int?
  optimizationCount    Int                   @default(0)
  pipelineStatus       PipelineStatus        @default(PENDING)
  pipelineVersion      Int?
  pipelineCheckpoint   Json?
  intentMatch          Float?
  contentDepth         Float?
  redundancyScore      Float?
  contentGaps          String[]
  lastAnalyzedAt       DateTime?
  publishedAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  site             Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keyword          Keyword           @relation(fields: [keywordId], references: [id], onDelete: Restrict)
  contentTasks     ContentTask[]
  seoMetrics       SeoMetric[]
  aiGenerationLogs AiGenerationLog[]
  pageKeywords     PageKeyword[]
  pillarSubjects   Subject[]     @relation("SubjectPillar")

  @@unique([siteId, slug, language])
  @@index([siteId, language, status])
  @@index([siteId, publishedAt])
  @@map("pages")
}

model ContentTask {
  id          Int        @id @default(autoincrement())
  siteId      Int?
  keywordId   Int?
  pageId      Int?
  type        TaskType   @default(GENERATE_CONTENT)
  status      TaskStatus @default(QUEUED)
  priority    Int        @default(0)
  payload     Json?
  result      Json?
  errorLog    String?    @db.Text
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  lockedAt    DateTime?
  lockedBy    String?
  currentStep String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  keyword Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  page    Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([keywordId])
  @@index([pageId])
  @@map("content_tasks")
}

model SeoMetric {
  id              Int      @id @default(autoincrement())
  siteId          Int
  pageId          Int?
  query           String?
  date            DateTime @db.Date
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  avgPosition     Float?
  ctrExpected     Float?
  ctrGap          Float?
  organicSessions Int      @default(0)
  bounceRate      Float?
  createdAt       DateTime @default(now())

  site Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  page Page? @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@unique([siteId, pageId, date])
  @@index([siteId, date])
  @@index([pageId, date])
  @@map("seo_metrics")
}

model KeywordResearch {
  id           Int                   @id @default(autoincrement())
  seedKeyword  String
  language     ContentLanguage
  suggestions  String[]
  source       KeywordResearchSource
  createdAt    DateTime              @default(now())

  @@index([seedKeyword, language])
  @@map("keyword_research")
}

model AiGenerationLog {
  id              Int                @id @default(autoincrement())
  pageId          Int
  pipelineVersion Int?
  stepKey         String
  provider        AiProvider
  model           String
  inputTokens     Int
  outputTokens    Int
  cost            Decimal            @db.Decimal(12, 6)
  durationMs      Int
  promptHash      String
  status          AiGenerationStatus
  createdAt       DateTime           @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([stepKey, createdAt])
  @@map("ai_generation_logs")
}

model SiteConfig {
  id               Int      @id @default(autoincrement())
  siteId           Int      @unique
  aiBudgetLimit    Decimal  @db.Decimal(12, 2)
  qualityThreshold Float    @default(70)
  pipelineConfig   Json
  modelConfig      Json
  promptConfig     Json
  runtimeConfig    Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_configs")
}

model PromptTemplate {
  id        Int      @id @default(autoincrement())
  siteId    Int?
  type      String
  version   String
  tone      String   @default("seo")
  locale    String?
  abVariant String?
  system    String?  @db.Text
  user      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site Site? @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([type, version, siteId, abVariant])
  @@index([siteId, type, isActive])
  @@map("prompt_templates")
}

model CostLedger {
  id           Int      @id @default(autoincrement())
  siteId       Int
  date         DateTime @db.Date
  totalCost    Decimal  @db.Decimal(12, 6)
  totalTokens  Int      @default(0)
  requestCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
  @@index([siteId, date])
  @@map("cost_ledger")
}

model PageKeyword {
  id        Int             @id @default(autoincrement())
  pageId    Int
  keywordId Int
  role      PageKeywordRole @default(SECONDARY)
  weight    Float           @default(0.5)
  createdAt DateTime        @default(now())

  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([pageId, keywordId])
  @@index([pageId, role])
  @@map("page_keywords")
}

model KeywordCluster {
  id                  Int           @id @default(autoincrement())
  siteId              Int
  mainKeywordId       Int           @unique
  intent              KeywordIntent
  topic               String
  semanticTopics      String[]
  secondaryKeywordIds Int[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  site        Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  mainKeyword Keyword @relation("ClusterMain", fields: [mainKeywordId], references: [id], onDelete: Cascade)

  @@index([siteId, intent])
  @@map("keyword_clusters")
}

model PlatformUser {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String
  displayName  String?
  role         PlatformRole @default(ADMIN)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("platform_users")
}

model VillaUser {
  id            Int            @id @default(autoincrement())
  email         String
  villaId       String
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@unique([email, villaId])
  @@index([villaId])
  @@map("villa_users")
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String
  villaId   String
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, villaId])
  @@map("otps")
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  jti         String    @unique
  tokenHash   String    @unique
  villaUserId Int
  villaUser   VillaUser @relation(fields: [villaUserId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([villaUserId])
  @@map("refresh_tokens")
}

model ContentTemplate {
  id                     Int         @id @default(autoincrement())
  name                   String
  description            String?
  contentType            ContentType @default(ARTICLE)
  requiredSections       Json
  headingStructure       Json
  seoRules               Json
  faqStructure           Json
  ctaPlacement           String?
  internalLinkingRules     Json?
  formattingInstructions String?     @db.Text
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  subjects Subject[]

  @@index([contentType, isActive])
  @@map("content_templates")
}

model Subject {
  id                        Int                      @id @default(autoincrement())
  siteId                    Int
  templateId                Int?
  title                     String
  description               String?                  @db.Text
  primaryKeywords           String[]
  secondaryKeywords         String[]
  searchIntent              KeywordIntent            @default(INFORMATIONAL)
  language                  ContentLanguage          @default(EN)
  country                   String?
  city                      String?
  seoGoal                   String?
  contentCountTarget        Int                      @default(10)
  hallucinationSensitivity  HallucinationSensitivity @default(MEDIUM)
  riskCategory              RiskCategory             @default(GENERAL)
  requiresFactualValidation Boolean                  @default(false)
  strictReviewMode          Boolean                  @default(false)
  status                    SubjectStatus            @default(ACTIVE)
  pillarPageId              Int?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  site         Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pillarPage   Page?            @relation("SubjectPillar", fields: [pillarPageId], references: [id], onDelete: SetNull)
  template     ContentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contentIdeas ContentIdea[]
  ideaTasks    IdeaTask[]

  @@index([siteId, status])
  @@index([templateId])
  @@map("subjects")
}

model ContentIdea {
  id                         Int           @id @default(autoincrement())
  subjectId                  Int
  title                      String
  slug                       String
  targetKeyword              String
  metaDescription            String?       @db.Text
  searchIntent               KeywordIntent @default(INFORMATIONAL)
  outline                    Json?
  headings                   String[]
  faqSuggestions             Json?
  internalLinkingSuggestions String[]
  contentType                ContentType   @default(ARTICLE)
  confidenceScore            Float         @default(0)
  hallucinationRiskScore     Float         @default(0)
  status                     IdeaStatus    @default(PENDING_REVIEW)
  reviewNotes                String?       @db.Text
  generatedBy                AiProvider?
  generatedModel             String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  ideaTasks IdeaTask[]

  @@unique([subjectId, slug])
  @@index([subjectId, status])
  @@index([subjectId, createdAt])
  @@map("content_ideas")
}

model IdeaTask {
  id          Int            @id @default(autoincrement())
  ideaId      Int
  subjectId   Int
  siteId      Int?
  type        TaskType       @default(GENERATE_CONTENT)
  status      IdeaTaskStatus @default(QUEUED)
  priority    Int            @default(0)
  payload     Json?
  result      Json?
  errorLog    String?        @db.Text
  attempts    Int            @default(0)
  maxAttempts Int            @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  lockedAt    DateTime?
  lockedBy    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  idea    ContentIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  subject Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  site    Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([subjectId])
  @@index([ideaId])
  @@map("idea_tasks")
}
