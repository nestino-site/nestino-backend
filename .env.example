DATABASE_URL="postgresql://user:password@localhost:5432/traffic_engine"
REDIS_URL="redis://localhost:6379"
PORT=3001
NODE_ENV="development"

# Platform operator auth (JWT)
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="8h"
ADMIN_EMAIL="admin@nestino.test"
ADMIN_PASSWORD="change-me-on-first-deploy"

# AI providers (optional if AI_STUB=true)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
AI_STUB="true"
AI_FALLBACK_OPENAI_MODEL="gpt-4o-mini"
AI_FALLBACK_ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
AI_FALLBACK_GOOGLE_MODEL="gemini-1.5-flash"

# Google Search Console / GA4 (optional; metrics sync skips API without keys)
GSC_CLIENT_EMAIL=""
GSC_PRIVATE_KEY=""
GA4_PROPERTY_ID=""
GA4_CLIENT_EMAIL=""
GA4_PRIVATE_KEY=""

# Cron patterns (optional; defaults in TrafficEngineSchedulerService)
METRICS_INGESTION_CRON="0 2 * * *"
PERFORMANCE_EVAL_CRON="0 4 * * *"

# Evaluation thresholds
UNDERPERFORM_CTR_THRESHOLD="0.02"
UNDERPERFORM_POSITION_THRESHOLD="20"
UNDERPERFORM_DAYS_OLD="30"
