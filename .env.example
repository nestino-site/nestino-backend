DATABASE_URL="postgresql://user:password@localhost:5432/traffic_engine"
REDIS_URL="redis://localhost:6379"
PORT=3001
NODE_ENV="development"

# Platform operator auth (JWT)
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="8h"

# Comma-separated browser origins for admin panel (CORS). Use * only for local experiments.
CORS_ORIGINS="http://localhost:5001,http://localhost:3000"
ADMIN_EMAIL="admin@nestino.test"
ADMIN_PASSWORD="change-me-on-first-deploy"

# AI providers (optional if AI_STUB=true)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
AI_STUB="true"
AI_FALLBACK_OPENAI_MODEL="gpt-4o-mini"
AI_FALLBACK_ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
AI_FALLBACK_GOOGLE_MODEL="gemini-1.5-flash"

# Google Search Console / GA4 (optional; metrics sync skips API without keys)
GSC_CLIENT_EMAIL=""
GSC_PRIVATE_KEY=""
GA4_PROPERTY_ID=""
GA4_CLIENT_EMAIL=""
GA4_PRIVATE_KEY=""

# Cron patterns (optional; defaults in TrafficEngineSchedulerService)
METRICS_INGESTION_CRON="0 2 * * *"
PERFORMANCE_EVAL_CRON="0 4 * * *"

# Evaluation thresholds
UNDERPERFORM_CTR_THRESHOLD="0.02"
UNDERPERFORM_POSITION_THRESHOLD="20"
UNDERPERFORM_DAYS_OLD="30"
UNDERPERFORM_MIN_IMPRESSIONS="100"
REWRITE_COOLDOWN_DAYS="14"

# Optional SerpAPI for real related queries (GET /keyword-research/enrich?seed=...)
SERPAPI_API_KEY=""
SERPAPI_TIMEOUT_MS="8000"

# Google Search Console service account JSON (single line) for future GSC pull
GSC_SERVICE_ACCOUNT_JSON=""

# Villa Silyan brand prompts
# Preferred: comma-separated site IDs (e.g. "3,7"). Takes precedence over domain heuristic.
VILLA_SILYAN_SITE_IDS=""
# Legacy: set true to enable for all sites (use VILLA_SILYAN_SITE_IDS instead)
ENABLE_VILLA_SILYAN_PROMPTS="false"

# Originality check thresholds
ORIGINALITY_MAX_OVERLAP="0.25"
ORIGINALITY_COMPARE_LIMIT="20"

# CDN base URL for generated page images. When set, publish uploads hero.webp and
# content API returns CDN URLs. Serve IMAGE_UPLOADS_DIR at this URL in production.
CDN_BASE_URL=""
IMAGE_UPLOADS_DIR="./uploads"

# Webhook retry (failed publish notifications)
WEBHOOK_RETRY_CRON="*/5 * * * *"
WEBHOOK_RETRY_BASE_MS="60000"
PUBLISH_WEBHOOK_TIMEOUT_MS="5000"

# GSC lookback window in days for metrics ingestion (default 28)
GSC_LOOKBACK_DAYS="28"
