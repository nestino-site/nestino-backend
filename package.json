    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "marked": "^18.0.2",
    "reflect-metadata": "^0.2.2",
