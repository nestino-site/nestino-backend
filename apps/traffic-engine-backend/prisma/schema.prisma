generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SiteStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PlatformRole {
  ADMIN
}

enum ContentLanguage {
  EN
  AR
  DE
  FR
  ES
  IT
  TR
  NL
  FA
}

enum ContentStrategy {
  BUDGET
  BALANCED
  QUALITY
}

enum KeywordIntent {
  INFORMATIONAL
  NAVIGATIONAL
  TRANSACTIONAL
  COMMERCIAL
}

enum KeywordStatus {
  PENDING
  IN_PROGRESS
  PUBLISHED
  FAILED
  SKIPPED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  NEEDS_UPDATE
  ARCHIVED
}

enum TaskStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskType {
  GENERATE_CONTENT
  REWRITE_CONTENT
  GENERATE_META
  GENERATE_SCHEMA
  GENERATE_IMAGE
  REFRESH_TITLE_META
}

enum AiProvider {
  openai
  anthropic
  google
}

enum AiGenerationStatus {
  SUCCESS
  FAILED
}

enum KeywordResearchSource {
  MANUAL
  AI
  GSC
}

enum PipelineStatus {
  PENDING
  GENERATING
  VALIDATING
  ANALYZING
  GEO_SCORING
  REWRITING
  IMAGE_GENERATING
  SEO_CHECKING
  READY
  FAILED
  PARTIALLY_COMPLETED
  SKIPPED_STEP
}

enum PageKeywordRole {
  PRIMARY
  SECONDARY
}

enum CannibalizationStatus {
  WINNER
  LOSER
  MONITOR
  NONE
}

enum SubjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum IdeaStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum HallucinationSensitivity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskCategory {
  GENERAL
  MEDICAL
  LEGAL
  FINANCIAL
  IMMIGRATION
  PRICING
}

enum ContentType {
  ARTICLE
  LANDING_PAGE
  CITY_PAGE
  FAQ
  COMPARISON
  BLOG_POST
}

enum IdeaTaskStatus {
  QUEUED
  PROCESSING
  GENERATED
  FAILED
  PUBLISHED
}

model Site {
  id                     Int              @id @default(autoincrement())
  name                   String
  domain                 String           @unique
  timezone               String           @default("UTC")
  status                 SiteStatus       @default(ACTIVE)
  config                 Json?

  defaultLanguage        ContentLanguage  @default(EN)
  languages              ContentLanguage[]
  strategy               ContentStrategy  @default(BALANCED)
  gscProperty            String?
  ga4PropertyId           String?
  aiPipeline             Json?

  publishWebhookUrl      String?
  publishWebhookSecret   String?
  autoPublish            Boolean          @default(true)
  contentApiKeyHash      String?
  contentApiKeyCreatedAt DateTime?

  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  keywords               Keyword[]
  pages                  Page[]
  seoMetrics             SeoMetric[]
  siteConfig             SiteConfig?
  promptTemplates        PromptTemplate[]
  costLedger             CostLedger[]
  keywordClusters        KeywordCluster[]
  subjects               Subject[]
  ideaTasks              IdeaTask[]
  topicalClusters        TopicalCluster[]
  webhookDeliveries      WebhookDelivery[]

  @@index([domain])
  @@map("sites")
}

model Keyword {
  id                   Int              @id @default(autoincrement())
  siteId               Int
  keyword              String
  language             ContentLanguage  @default(EN)
  baseKeywordId        Int?
  intent               KeywordIntent    @default(INFORMATIONAL)
  status               KeywordStatus    @default(PENDING)
  searchVolume         Int?
  difficulty           Float?
  cpc                  Float?
  priority             Int              @default(0)
  cannibalizationGroup String?
  targetUrl            String?
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  site            Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  baseKeyword     Keyword?         @relation("KeywordCluster", fields: [baseKeywordId], references: [id], onDelete: SetNull)
  derivedKeywords Keyword[]        @relation("KeywordCluster")
  pages           Page[]
  contentTasks    ContentTask[]
  pageKeywords    PageKeyword[]
  cluster         KeywordCluster?  @relation("ClusterMain")

  @@unique([siteId, keyword, language])
  @@index([siteId, status])
  @@index([siteId, priority])
  @@index([siteId, language])
  @@index([baseKeywordId])
  @@map("keywords")
}

model Page {
  id                   Int                   @id @default(autoincrement())
  siteId               Int
  keywordId            Int
  language             ContentLanguage       @default(EN)
  slug                 String
  title                String?
  metaTitle            String?
  metaDescription      String?
  outline              Json?
  rawDraft             String?               @db.Text
  finalContent         String?               @db.Text
  htmlContent          String?               @db.Text
  tableOfContents      Json?
  faq                  Json?
  imagePrompt          String?               @db.Text
  generatedImageBase64 String?               @db.Text
  generatedImageCdnUrl String?
  schemaMarkup         Json?
  status               PageStatus            @default(DRAFT)
  seoScore             Float?
  seoCheckScore        Int?
  seoCheckPassed       Boolean?
  seoCheckIssues       Json?
  contentAuditResult   Json?
  geoScore             Float?
  geoScorePillars      Json?
  cannibalizationStatus CannibalizationStatus @default(NONE)
  readabilityScore     Float?
  wordCount            Int?
  optimizationCount    Int                   @default(0)
  pipelineStatus       PipelineStatus        @default(PENDING)
  pipelineVersion      Int?
  pipelineCheckpoint   Json?
  intentMatch          Float?
  contentDepth         Float?
  redundancyScore      Float?
  contentGaps          String[]
  lastAnalyzedAt       DateTime?
  publishedAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  site             Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keyword          Keyword           @relation(fields: [keywordId], references: [id], onDelete: Restrict)
  contentTasks     ContentTask[]
  seoMetrics       SeoMetric[]
  aiGenerationLogs AiGenerationLog[]
  pageKeywords     PageKeyword[]
  pillarSubjects   Subject[]         @relation("SubjectPillar")
  topicalClusters  TopicalCluster[]  @relation("TopicalClusterPillar")
  webhookDeliveries WebhookDelivery[]

  @@unique([siteId, slug, language])
  @@index([siteId, language, status])
  @@index([siteId, publishedAt])
  @@index([siteId, createdAt])
  @@map("pages")
}

model ContentTask {
  id          Int        @id @default(autoincrement())
  siteId      Int?
  keywordId   Int?
  pageId      Int?
  type        TaskType   @default(GENERATE_CONTENT)
  status      TaskStatus @default(QUEUED)
  priority    Int        @default(0)
  payload     Json?
  result      Json?
  errorLog    String?    @db.Text
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  lockedAt    DateTime?
  lockedBy    String?
  currentStep String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  keyword Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  page    Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([keywordId])
  @@index([pageId])
  @@map("content_tasks")
}

model SeoMetric {
  id              Int      @id @default(autoincrement())
  siteId          Int
  pageId          Int?
  query           String?
  date            DateTime @db.Date
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  ctr             Float    @default(0)
  avgPosition     Float?
  ctrExpected     Float?
  ctrGap          Float?
  organicSessions Int      @default(0)
  bounceRate      Float?
  createdAt       DateTime @default(now())

  site Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  page Page? @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@unique([siteId, pageId, date])
  @@index([siteId, date])
  @@index([pageId, date])
  @@map("seo_metrics")
}

model KeywordResearch {
  id           Int                   @id @default(autoincrement())
  seedKeyword  String
  language     ContentLanguage
  suggestions  String[]
  source       KeywordResearchSource
  createdAt    DateTime              @default(now())

  @@index([seedKeyword, language])
  @@map("keyword_research")
}

model AiGenerationLog {
  id              Int                @id @default(autoincrement())
  pageId          Int
  pipelineVersion Int?
  stepKey         String
  provider        AiProvider
  model           String
  inputTokens     Int
  outputTokens    Int
  cost            Decimal            @db.Decimal(12, 6)
  durationMs      Int
  promptHash      String
  status          AiGenerationStatus
  createdAt       DateTime           @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
  @@index([stepKey, createdAt])
  @@map("ai_generation_logs")
}

model SiteConfig {
  id               Int      @id @default(autoincrement())
  siteId           Int      @unique
  aiBudgetLimit    Decimal  @db.Decimal(12, 2)
  qualityThreshold Float    @default(70)
  pipelineConfig   Json
  modelConfig      Json
  promptConfig     Json
  runtimeConfig    Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_configs")
}

model PromptTemplate {
  id        Int      @id @default(autoincrement())
  siteId    Int?
  type      String
  version   String
  tone      String   @default("seo")
  locale    String?
  abVariant String?
  system    String?  @db.Text
  user      String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site Site? @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([type, version, siteId, abVariant])
  @@index([siteId, type, isActive])
  @@map("prompt_templates")
}

model CostLedger {
  id           Int      @id @default(autoincrement())
  siteId       Int
  date         DateTime @db.Date
  totalCost    Decimal  @db.Decimal(12, 6)
  totalTokens  Int      @default(0)
  requestCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
  @@index([siteId, date])
  @@map("cost_ledger")
}

model PageKeyword {
  id        Int             @id @default(autoincrement())
  pageId    Int
  keywordId Int
  role      PageKeywordRole @default(SECONDARY)
  weight    Float           @default(0.5)
  createdAt DateTime        @default(now())

  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([pageId, keywordId])
  @@index([pageId, role])
  @@map("page_keywords")
}

model KeywordCluster {
  id                  Int           @id @default(autoincrement())
  siteId              Int
  mainKeywordId       Int           @unique
  intent              KeywordIntent
  topic               String
  semanticTopics      String[]
  secondaryKeywordIds Int[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  site        Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  mainKeyword Keyword @relation("ClusterMain", fields: [mainKeywordId], references: [id], onDelete: Cascade)

  @@index([siteId, intent])
  @@map("keyword_clusters")
}

model PlatformUser {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String
  displayName  String?
  role         PlatformRole @default(ADMIN)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("platform_users")
}

model VillaUser {
  id            Int            @id @default(autoincrement())
  email         String
  villaId       String
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@unique([email, villaId])
  @@index([villaId])
  @@map("villa_users")
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String
  villaId   String
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, villaId])
  @@map("otps")
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  jti         String    @unique
  tokenHash   String    @unique
  villaUserId Int
  villaUser   VillaUser @relation(fields: [villaUserId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([villaUserId])
  @@map("refresh_tokens")
}

model ContentTemplate {
  id                     Int         @id @default(autoincrement())
  name                   String
  description            String?
  contentType            ContentType @default(ARTICLE)
  requiredSections       Json
  headingStructure       Json
  seoRules               Json
  faqStructure           Json
  ctaPlacement           String?
  internalLinkingRules     Json?
  formattingInstructions String?     @db.Text
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  subjects Subject[]

  @@index([contentType, isActive])
  @@map("content_templates")
}

model Subject {
  id                        Int                      @id @default(autoincrement())
  siteId                    Int
  templateId                Int?
  title                     String
  description               String?                  @db.Text
  primaryKeywords           String[]
  secondaryKeywords         String[]
  searchIntent              KeywordIntent            @default(INFORMATIONAL)
  language                  ContentLanguage          @default(EN)
  country                   String?
  city                      String?
  seoGoal                   String?
  contentCountTarget        Int                      @default(10)
  hallucinationSensitivity  HallucinationSensitivity @default(MEDIUM)
  riskCategory              RiskCategory             @default(GENERAL)
  requiresFactualValidation Boolean                  @default(false)
  strictReviewMode          Boolean                  @default(false)
  status                    SubjectStatus            @default(ACTIVE)
  pillarPageId              Int?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  site         Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pillarPage   Page?            @relation("SubjectPillar", fields: [pillarPageId], references: [id], onDelete: SetNull)
  template     ContentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contentIdeas ContentIdea[]
  ideaTasks    IdeaTask[]

  @@index([siteId, status])
  @@index([templateId])
  @@map("subjects")
}

model ContentIdea {
  id                         Int           @id @default(autoincrement())
  subjectId                  Int
  title                      String
  slug                       String
  targetKeyword              String
  metaDescription            String?       @db.Text
  searchIntent               KeywordIntent @default(INFORMATIONAL)
  outline                    Json?
  headings                   String[]
  faqSuggestions             Json?
  internalLinkingSuggestions String[]
  contentType                ContentType   @default(ARTICLE)
  confidenceScore            Float         @default(0)
  hallucinationRiskScore     Float         @default(0)
  status                     IdeaStatus    @default(PENDING_REVIEW)
  reviewNotes                String?       @db.Text
  generatedBy                AiProvider?
  generatedModel             String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  ideaTasks IdeaTask[]

  @@unique([subjectId, slug])
  @@index([subjectId, status])
  @@index([subjectId, createdAt])
  @@map("content_ideas")
}

model IdeaTask {
  id          Int            @id @default(autoincrement())
  ideaId      Int
  subjectId   Int
  siteId      Int?
  type        TaskType       @default(GENERATE_CONTENT)
  status      IdeaTaskStatus @default(QUEUED)
  priority    Int            @default(0)
  payload     Json?
  result      Json?
  errorLog    String?        @db.Text
  attempts    Int            @default(0)
  maxAttempts Int            @default(3)
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  lockedAt    DateTime?
  lockedBy    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  idea    ContentIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  subject Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  site    Site?       @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([subjectId])
  @@index([ideaId])
  @@map("idea_tasks")
}

model TopicalCluster {
  id          Int      @id @default(autoincrement())
  siteId      Int
  name        String
  pillarSlug  String?
  pillarPageId Int?
  topics      String[]
  entities    String[]
  coverageGap String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site         Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pillarPage   Page? @relation("TopicalClusterPillar", fields: [pillarPageId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@map("topical_clusters")
}

model SerpSnapshot {
  id             Int      @id @default(autoincrement())
  keyword        String
  language       String
  country        String   @default("us")
  organicTitles  String[]
  organicSnippets String[]
  organicLinks   String[]
  paaQuestions   String[]
  relatedSearches String[]
  entities       String[]
  searchVolume   Int?
  difficulty     Float?
  hasAiOverview  Boolean  @default(false)
  hasFaqFeature  Boolean  @default(false)
  hasVideoFeature Boolean @default(false)
  hasImagePack   Boolean  @default(false)
  rawData        Json?
  capturedAt     DateTime @default(now())

  @@unique([keyword, language, country])
  @@index([keyword, language])
  @@map("serp_snapshots")
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

enum WebhookEventType {
  CLINIC_PUBLISHED
  CLINIC_UPDATED
  TRUTH_SCORE_CHANGED
}

enum DestinationPhase {
  PHASE_1
  PHASE_2
  PHASE_3
}

enum ClinicStatus {
  DISCOVERED
  ENRICHING
  REVIEW_PENDING
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum MediaKind {
  PHOTO
  LOGO
  VIDEO
}

enum InterviewStatus {
  DRAFT
  IN_REVIEW
  VERIFIED
  PUBLISHED
  REJECTED
}

enum QuestionType {
  LIKERT
  NUMBER
  YES_NO
  TEXT
  CHOICE
}

enum TruthScoreGrade {
  A
  B
  C
  D
  F
}

enum TruthScoreStatus {
  PENDING
  LIVE
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscoveryRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum DiscoveryTrigger {
  CRON
  ADMIN
  API
}

enum CandidateStatus {
  NEW
  DEDUPED
  ENRICHING
  READY_FOR_REVIEW
  AUTO_PUBLISHED
  REJECTED
  FAILED
}

model WebhookDelivery {
  id           Int                   @id @default(autoincrement())
  siteId       Int
  pageId       Int
  url          String
  payload      Json
  signature    String
  status       WebhookDeliveryStatus @default(PENDING)
  attempts     Int                   @default(0)
  maxAttempts  Int                   @default(5)
  lastStatus   Int?
  lastError    String?
  nextRetryAt  DateTime              @default(now())
  deliveredAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([pageId])
  @@map("webhook_deliveries")
}

// ─── Clinic Inventory (merged from apps/clinic-inventory) ─────────────────────

model Country {
  id              Int      @id @default(autoincrement())
  codeIso2        String   @unique @db.Char(2)
  name            String
  defaultCurrency String   @default("EUR") @db.Char(3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cities  City[]
  clinics Clinic[]

  @@map("countries")
}

model City {
  id                  Int              @id @default(autoincrement())
  countryId           Int
  name                String
  slug                String           @unique
  lat                 Decimal?         @db.Decimal(10, 7)
  lng                 Decimal?         @db.Decimal(10, 7)
  phase               DestinationPhase @default(PHASE_1)
  isActiveDestination Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  country         Country          @relation(fields: [countryId], references: [id], onDelete: Cascade)
  clinics         Clinic[]
  discoveryRuns   DiscoveryRun[]
  discoveryConfig DiscoveryConfig?

  @@index([countryId])
  @@index([slug])
  @@map("cities")
}

model Treatment {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinicTreatments ClinicTreatment[]
  pricingPackages  ClinicPricingPackage[]

  @@map("treatments")
}

model Accreditation {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String
  regulator   String?
  countryCode String?  @db.Char(2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinicAccreditations ClinicAccreditation[]

  @@map("accreditations")
}

model Clinic {
  id                Int          @id @default(autoincrement())
  slug              String       @unique
  name              String
  cityId            Int?
  countryId         Int?
  addressLine       String?      @db.Text
  lat               Decimal?     @db.Decimal(10, 7)
  lng               Decimal?     @db.Decimal(10, 7)
  geohash           String?      @db.VarChar(12)
  websiteUrl        String?      @db.Text
  phone             String?      @db.VarChar(50)
  email             String?      @db.VarChar(255)
  languages         String[]
  foundedYear       Int?
  doctorsCount      Int?
  inHouseLab        Boolean      @default(false)
  shortDescription  String?      @db.VarChar(500)
  longDescription   String?      @db.Text
  heroImageUrl      String?      @db.Text
  googlePlaceId     String?      @unique @db.VarChar(255)
  googleRating      Decimal?     @db.Decimal(3, 1)
  googleReviewCount Int?
  openingHours      Json?
  googleMapsUrl     String?      @db.Text
  editorialSummary  String?      @db.VarChar(1000)
  priceLevel        Int?
  formattedPhone    String?      @db.VarChar(50)
  placeTypes        String[]     @default([])
  googlePhotos      Json?
  googleReviews     Json?
  status            ClinicStatus @default(DISCOVERED)
  confidenceScore   Float?
  sourcePayload     Json?
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  city    City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)
  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  treatments        ClinicTreatment[]
  accreditations    ClinicAccreditation[]
  pricingPackages   ClinicPricingPackage[]
  media             ClinicMedia[]
  doctors           ClinicDoctor[]
  interviews        PatientInterview[]
  truthScore        ClinicTruthScore?
  truthScoreSnaps   ClinicTruthScoreSnapshot[]
  reviews           ClinicReview[]
  webhookDeliveries ClinicWebhookDelivery[]

  @@index([cityId, status])
  @@index([status])
  @@index([slug])
  @@map("clinics")
}

model ClinicTreatment {
  clinicId         Int
  treatmentId      Int
  isOffered        Boolean  @default(true)
  notes            String?  @db.Text
  successRateRange Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clinic    Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@id([clinicId, treatmentId])
  @@map("clinic_treatments")
}

model ClinicAccreditation {
  clinicId        Int
  accreditationId Int
  validFrom       DateTime? @db.Date
  validTo         DateTime? @db.Date
  certUrl         String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  accreditation Accreditation @relation(fields: [accreditationId], references: [id], onDelete: Cascade)

  @@id([clinicId, accreditationId])
  @@map("clinic_accreditations")
}

model ClinicPricingPackage {
  id             Int       @id @default(autoincrement())
  clinicId       Int
  treatmentId    Int?
  packageName    String
  currency       String    @default("EUR") @db.Char(3)
  basePrice      Decimal?  @db.Decimal(12, 2)
  priceMin       Decimal?  @db.Decimal(12, 2)
  priceMax       Decimal?  @db.Decimal(12, 2)
  includes       Json?
  excludes       Json?
  notes          String?   @db.Text
  effectiveFrom  DateTime? @db.Date
  effectiveTo    DateTime? @db.Date
  sourceUrl      String?   @db.Text
  lastVerifiedAt DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  clinic    Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  treatment Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)

  @@index([clinicId, isActive])
  @@map("clinic_pricing_packages")
}

model ClinicMedia {
  id           Int       @id @default(autoincrement())
  clinicId     Int
  kind         MediaKind @default(PHOTO)
  url          String    @db.Text
  caption      String?   @db.VarChar(500)
  displayOrder Int       @default(0)
  isPrimary    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, displayOrder])
  @@map("clinic_media")
}

model ClinicDoctor {
  id          Int      @id @default(autoincrement())
  clinicId    Int
  name        String
  title       String?
  specialties String[]
  profileUrl  String?  @db.Text
  photoUrl    String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("clinic_doctors")
}

model TruthScoreDimension {
  code        String   @id @db.VarChar(50)
  name        String
  description String?  @db.Text
  weight      Decimal  @default(0.10) @db.Decimal(4, 3)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions InterviewQuestion[]
  answers   InterviewAnswer[]

  @@map("truth_score_dimensions")
}

model InterviewQuestion {
  code          String       @id @db.VarChar(100)
  dimensionCode String       @db.VarChar(50)
  prompt        String       @db.Text
  type          QuestionType @default(LIKERT)
  options       Json?
  sortOrder     Int          @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  dimension TruthScoreDimension @relation(fields: [dimensionCode], references: [code], onDelete: Cascade)
  answers   InterviewAnswer[]

  @@index([dimensionCode, isActive])
  @@map("interview_questions")
}

model PatientInterview {
  id               Int             @id @default(autoincrement())
  clinicId         Int
  language         String          @default("en") @db.VarChar(10)
  ageBucket        String?         @db.VarChar(20)
  originCountry    String?         @db.Char(2)
  treatmentCode    String?         @db.VarChar(50)
  completedYear    Int?
  status           InterviewStatus @default(DRAFT)
  consentGiven     Boolean         @default(false)
  consentTimestamp DateTime?
  aiSessionId      String?         @db.VarChar(255)
  quotes           Json?
  publishedAt      DateTime?
  verifiedBy       String?         @db.VarChar(255)
  verifiedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  clinic  Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  answers InterviewAnswer[]

  @@index([clinicId, status])
  @@map("patient_interviews")
}

model InterviewAnswer {
  id            Int      @id @default(autoincrement())
  interviewId   Int
  questionCode  String   @db.VarChar(100)
  dimensionCode String   @db.VarChar(50)
  valueNum      Float?
  valueText     String?  @db.Text
  scoredValue   Float?
  createdAt     DateTime @default(now())

  interview PatientInterview    @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question  InterviewQuestion   @relation(fields: [questionCode], references: [code], onDelete: Cascade)
  dimension TruthScoreDimension @relation(fields: [dimensionCode], references: [code], onDelete: Cascade)

  @@unique([interviewId, questionCode])
  @@index([interviewId])
  @@map("interview_answers")
}

model ClinicTruthScore {
  clinicId        Int              @id
  composite       Int?
  grade           TruthScoreGrade?
  dimensionScores Json?
  interviewCount  Int              @default(0)
  status          TruthScoreStatus @default(PENDING)
  lastComputedAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_truth_scores")
}

model ClinicTruthScoreSnapshot {
  id              Int              @id @default(autoincrement())
  clinicId        Int
  composite       Int?
  grade           TruthScoreGrade?
  dimensionScores Json?
  interviewCount  Int
  computedAt      DateTime         @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, computedAt])
  @@map("clinic_truth_score_snapshots")
}

model ClinicReview {
  id                 Int          @id @default(autoincrement())
  clinicId           Int
  rating             Int
  title              String?      @db.VarChar(255)
  body               String?      @db.Text
  language           String       @default("en") @db.VarChar(10)
  status             ReviewStatus @default(PENDING)
  submitterEmailHash String?      @db.VarChar(64)
  helpfulCount       Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status])
  @@map("clinic_reviews")
}

model DiscoveryRun {
  id             Int                @id @default(autoincrement())
  cityId         Int
  triggeredBy    DiscoveryTrigger   @default(ADMIN)
  status         DiscoveryRunStatus @default(QUEUED)
  dryRun         Boolean            @default(false)
  configOverride Json?
  configSnapshot Json?
  stats          Json?
  errorLog       String?            @db.Text
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  city       City                 @relation(fields: [cityId], references: [id], onDelete: Cascade)
  candidates DiscoveryCandidate[]

  @@index([cityId, status])
  @@index([status, createdAt])
  @@map("discovery_runs")
}

model DiscoveryCandidate {
  id                  Int             @id @default(autoincrement())
  runId               Int
  cityId              Int
  rawName             String?
  googlePlaceId       String?         @db.VarChar(255)
  websiteUrl          String?         @db.Text
  addressLine         String?         @db.Text
  lat                 Decimal?        @db.Decimal(10, 7)
  lng                 Decimal?        @db.Decimal(10, 7)
  dedupKey            String          @db.VarChar(64)
  matchedClinicId     Int?
  enrichmentPayload   Json?
  stepLog             Json?
  status              CandidateStatus @default(NEW)
  confidenceScore     Float?
  confidenceBreakdown Json?
  reviewerNotes       String?         @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  run DiscoveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, dedupKey])
  @@index([runId, status])
  @@index([cityId, status])
  @@map("discovery_candidates")
}

model AuditEvent {
  id         Int      @id @default(autoincrement())
  entityType String   @db.VarChar(100)
  entityId   String   @db.VarChar(100)
  actor      String?  @db.VarChar(255)
  type       String   @db.VarChar(100)
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_events")
}

model SystemConfig {
  id        Int      @id @default(1)
  defaults  Json
  version   Int      @default(1)
  updatedBy String?  @db.VarChar(255)
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model DiscoveryConfig {
  cityId              Int      @id
  version             Int      @default(1)
  pipeline            Json
  budgets             Json?
  rateLimits          Json?
  schedule            Json?
  truthScoreOverrides Json?
  observability       Json?
  isActive            Boolean  @default(true)
  updatedBy           String?  @db.VarChar(255)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())

  city     City                     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  versions DiscoveryConfigVersion[]

  @@map("discovery_configs")
}

model DiscoveryConfigVersion {
  id        Int      @id @default(autoincrement())
  cityId    Int
  version   Int
  payload   Json
  createdAt DateTime @default(now())
  createdBy String?  @db.VarChar(255)

  config DiscoveryConfig @relation(fields: [cityId], references: [cityId], onDelete: Cascade)

  @@unique([cityId, version])
  @@index([cityId, version])
  @@map("discovery_config_versions")
}

model ClinicWebhookDelivery {
  id          Int                   @id @default(autoincrement())
  clinicId    Int
  event       WebhookEventType
  url         String                @db.Text
  payload     Json
  signature   String                @db.VarChar(128)
  status      WebhookDeliveryStatus @default(PENDING)
  attempts    Int                   @default(0)
  maxAttempts Int                   @default(5)
  lastStatus  Int?
  lastError   String?               @db.Text
  nextRetryAt DateTime              @default(now())
  deliveredAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([clinicId])
  @@map("clinic_webhook_deliveries")
}
