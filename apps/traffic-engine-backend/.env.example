DATABASE_URL="postgresql://user:password@localhost:5432/traffic_engine"
REDIS_URL="redis://localhost:6379"
PORT=3001
NODE_ENV="development"

# Platform operator auth (JWT)
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="8h"

# HMAC secret for site content API keys (fast verify vs bcrypt). Use a long random string in production.
SITE_API_KEY_HMAC_SECRET="change-me-site-api-key-hmac-secret-at-least-32-chars"

# Comma-separated browser origins for admin panel (CORS). No trailing slash. Use * only for local experiments.
# Production: include your Vercel URL(s), e.g. https://adminpanel-seven-red.vercel.app
CORS_ORIGINS="http://localhost:5001,http://localhost:3000,https://adminpanel-seven-red.vercel.app"
ADMIN_EMAIL="admin@nestino.test"
ADMIN_PASSWORD="change-me-on-first-deploy"

# ─── AI Gateway ───────────────────────────────────────────────────────────────
# Conduit: one key, every model (https://conduit.ozdoev.net).
# Default gateway for all text AI actions. Get your key at conduit.ozdoev.net.
CONDUIT_API_KEY=""
# CONDUIT_BASE_URL="https://conduit.ozdoev.net/api/v1"   # optional, this is the default

# AI_GATEWAY_PROVIDER controls which provider is used for all actions by default.
# Supported values: conduit (default) | openai | anthropic | google
AI_GATEWAY_PROVIDER="conduit"

# Per-action overrides — set to change a single action without affecting others.
# Actions: generate, analyze, rewrite, seo_check, linking, enrich, ideas
# Example: use native OpenAI just for content generation
# AI_PROVIDER_GENERATE=openai
# AI_PROVIDER_ANALYZE=conduit
# AI_PROVIDER_REWRITE=conduit
# AI_PROVIDER_SEO_CHECK=conduit
# AI_PROVIDER_LINKING=conduit
# AI_PROVIDER_ENRICH=conduit
# AI_PROVIDER_IDEAS=conduit

# Fallback chain — comma-separated list of providers tried in order on transient failure.
# Default: conduit,openai,anthropic,google
# AI_FALLBACK_ORDER="conduit,openai,anthropic,google"

# Fallback models used when switching provider after a failure
AI_FALLBACK_CONDUIT_MODEL="gpt-4o-mini"
AI_FALLBACK_OPENAI_MODEL="gpt-4o-mini"
AI_FALLBACK_ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
AI_FALLBACK_GOOGLE_MODEL="gemini-1.5-flash"

# LLM_GATEWAY_PROVIDER controls the JSON-only LLM client (internal linking + clinic enrichment).
# Supported values: conduit (default) | openmodel
# conduit uses CONDUIT_API_KEY; openmodel uses OPENMODEL_API_KEY
LLM_GATEWAY_PROVIDER="conduit"
# CONDUIT_LLM_MODEL="gpt-4o-mini"        # model used for JSON actions via Conduit (default: gpt-4o-mini)
# CONDUIT_LLM_TIMEOUT_MS="90000"

# ─── YMYL Audit provider ─────────────────────────────────────────────────────
# conduit = chat completions via Conduit (default; works without Google key)
# google  = Gemini 2.5 Pro with Google Search Grounding (requires GOOGLE_AI_API_KEY)
YMYL_AUDIT_PROVIDER="conduit"
# Model used by the Conduit audit path (claude-opus-4-5 recommended for medical accuracy)
CONDUIT_AUDIT_MODEL="claude-opus-4-5"

# ─── Native AI provider keys (used as fallback or when overriding specific actions) ─
# Optional if AI_GATEWAY_PROVIDER=conduit and all actions stay on Conduit.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
# Also used for YMYL content audit (Gemini 2.5 Pro + Google Search Grounding in seo_check + POST /pages/:id/audit)
# Hero images via Google Imagen 4 (pipeline v3 image_generation step; Imagen 3 is shut down on Gemini API)
IMAGEN_MODEL="imagen-4.0-generate-001"
# Optional overrides: imagen-4.0-fast-generate-001 | imagen-4.0-ultra-generate-001
# IMAGEN_ASPECT_RATIO="16:9"
# IMAGEN_IMAGE_SIZE="1K"
AI_STUB="true"

# Idea generation (default provider follows AI_GATEWAY_PROVIDER)
AI_IDEA_GENERATION_MODEL="gemini-3.1-flash-lite"
AI_IDEA_OPENAI_MODEL="gpt-4o-mini"
AI_IDEA_ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# Google Search Console (optional; metrics sync skips API without credentials)
# 1. GCP: enable Search Console API, create service account, download JSON key
# 2. Search Console: add service account email as user on the property (Viewer is enough)
# 3. Convert key to single-line JSON: bash scripts/convert-gsc-credentials-to-env.sh path/to/key.json
# 4. Paste output into GSC_SERVICE_ACCOUNT_JSON below (never commit the key file)
# 5. Set each site's gscProperty via PATCH /sites/:id (e.g. "sc-domain:medcover.io")
GSC_SERVICE_ACCOUNT_JSON=""
GSC_LOOKBACK_DAYS="28"

# Legacy split credentials (not used by gsc-ingestion.service; kept for reference)
GSC_CLIENT_EMAIL=""
GSC_PRIVATE_KEY=""

# Google Analytics 4 (optional; ga4-ingestion stub skips until implemented)
GA4_PROPERTY_ID=""
GA4_CLIENT_EMAIL=""
GA4_PRIVATE_KEY=""

# Cron patterns (optional; defaults in TrafficEngineSchedulerService)
METRICS_INGESTION_CRON="0 2 * * *"
PERFORMANCE_EVAL_CRON="0 4 * * *"

# Evaluation thresholds
UNDERPERFORM_CTR_THRESHOLD="0.02"
UNDERPERFORM_POSITION_THRESHOLD="20"
UNDERPERFORM_DAYS_OLD="30"
UNDERPERFORM_MIN_IMPRESSIONS="100"
REWRITE_COOLDOWN_DAYS="14"

# Optional SerpAPI for real related queries (GET /keyword-research/enrich?seed=...)
SERPAPI_API_KEY=""
SERPAPI_TIMEOUT_MS="8000"

# Villa Silyan brand prompts
# Preferred: comma-separated site IDs (e.g. "3,7"). Takes precedence over domain heuristic.
VILLA_SILYAN_SITE_IDS=""
# Legacy: set true to enable for all sites (use VILLA_SILYAN_SITE_IDS instead)
ENABLE_VILLA_SILYAN_PROMPTS="false"

# Originality check thresholds
ORIGINALITY_MAX_OVERLAP="0.25"
ORIGINALITY_COMPARE_LIMIT="20"

# Cloudinary CDN for page hero images and clinic photos.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# When set:
#   - PageHeroCdnService uploads hero images on publish → generatedImageCdnUrl
#   - ClinicPhotoCdnService uploads clinic Google photos on publish → heroImageUrl
#     and listing/detail pages embed res.cloudinary.com URLs (reliable on MedCover).
# Without CLOUDINARY_URL, clinic photos are served via GET /clinics/:id/photo (streamed proxy).
CLOUDINARY_URL=""

# Comma-separated origins for browser API calls (include your frontend production URL).
# CORS_ORIGINS="https://medcover.io,https://www.medcover.io"

# Webhook retry (failed publish notifications)
WEBHOOK_RETRY_CRON="*/5 * * * *"
WEBHOOK_RETRY_BASE_MS="60000"
PUBLISH_WEBHOOK_TIMEOUT_MS="5000"

# Telegram ops alerts (AI provider billing/quota failures — never commit real token)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# TELEGRAM_ALERTS_ENABLED="true"
# TELEGRAM_BILLING_ALERT_COOLDOWN_SEC="3600"

# GSC lookback window in days for metrics ingestion (default 28)
# GSC_LOOKBACK_DAYS moved above with GSC_SERVICE_ACCOUNT_JSON

# Per-site maturity gate: automation stays OFF until ALL thresholds are met, then auto-unlocks
MATURITY_MIN_AGE_DAYS="60"
MATURITY_MIN_IMPRESSIONS="5000"
MATURITY_MIN_QUERY_ROWS="50"
MATURITY_MIN_INDEXED_PAGES="10"

# GSC feedback loop thresholds (winners + orphan queries -> new content ideas)
GSC_FEEDBACK_MIN_IMPRESSIONS="100"
GSC_FEEDBACK_MIN_CLICKS="3"
GSC_FEEDBACK_MAX_IDEAS_PER_SYNC="10"
GSC_TREND_LOOKBACK_DAYS="28"

# LLM GSC strategist (POST /analytics/:siteId/strategist-run)
GSC_STRATEGIST_MAX_CANDIDATES="80"
GSC_STRATEGIST_MAX_OPPORTUNITIES="15"
GSC_STRATEGIST_MIN_IMPRESSIONS="50"
GSC_STRATEGIST_MIN_POSITION="5"
GSC_STRATEGIST_MAX_POSITION="30"
# Comma-separated branded terms to exclude from strategist candidates
GSC_STRATEGIST_BRAND_TERMS="medcover,nestino,villa silyan,sindibed"

# OpenModel — fallback LLM client for enrichment/linking (used when LLM_GATEWAY_PROVIDER=openmodel)
# deepseek-v4-flash uses the Anthropic Messages API (/v1/messages), not Chat Completions.
# Not needed when LLM_GATEWAY_PROVIDER=conduit (the default).
OPENMODEL_API_KEY=""
OPENMODEL_BASE_URL=https://api.openmodel.ai/v1
OPENMODEL_MODEL=deepseek-v4-flash
OPENMODEL_TIMEOUT_MS="90000"

# Clinic inventory (Google Places discovery — merged into traffic-engine)
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACES_USE_NEW_API="true"
GOOGLE_PLACES_DAILY_QUOTA="1000"
DISCOVERY_GLOBAL_KILL_SWITCH="false"
DISCOVERY_LLM_DISABLED="false"
DISCOVERY_DRY_RUN_DEFAULT="false"
MIN_INTERVIEWS_FOR_LIVE="5"

# Clinic pages are written to the MedCover site by domain. Defaults to medcover.io.
CLINIC_SITE_DOMAIN=medcover.io
# Optional: only needed for external HTTP callers of POST /clinic-inventory/webhook
TRAFFIC_ENGINE_WEBHOOK_SECRET=change_me_in_production

# MedCover production setup
# Run scripts/seed-medcover.sh against Railway to create/update medcover.com,
# seed ContentTemplates and Subjects, and rotate the frontend content API key.
# Store the printed content API key in the Next.js frontend environment, not here.
