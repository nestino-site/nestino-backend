DATABASE_URL="postgresql://user:password@localhost:5432/traffic_engine"
REDIS_URL="redis://localhost:6379"
PORT=3001
NODE_ENV="development"

# Platform operator auth (JWT)
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="8h"

# HMAC secret for site content API keys (fast verify vs bcrypt). Use a long random string in production.
SITE_API_KEY_HMAC_SECRET="change-me-site-api-key-hmac-secret-at-least-32-chars"

# Comma-separated browser origins for admin panel (CORS). No trailing slash. Use * only for local experiments.
# Production: include your Vercel URL(s), e.g. https://adminpanel-seven-red.vercel.app
CORS_ORIGINS="http://localhost:5001,http://localhost:3000,https://adminpanel-seven-red.vercel.app"
ADMIN_EMAIL="admin@nestino.test"
ADMIN_PASSWORD="change-me-on-first-deploy"

# AI providers (optional if AI_STUB=true)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
# Also used for YMYL content audit (Gemini 2.5 Pro + Google Search Grounding in seo_check + POST /pages/:id/audit)
# Hero images via Google Imagen 4 (pipeline v3 image_generation step; Imagen 3 is shut down on Gemini API)
IMAGEN_MODEL="imagen-4.0-generate-001"
# Optional overrides: imagen-4.0-fast-generate-001 | imagen-4.0-ultra-generate-001
# IMAGEN_ASPECT_RATIO="16:9"
# IMAGEN_IMAGE_SIZE="1K"
AI_STUB="true"
AI_FALLBACK_OPENAI_MODEL="gpt-4o-mini"
AI_FALLBACK_ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
AI_FALLBACK_GOOGLE_MODEL="gemini-1.5-flash"

# Idea generation (default provider: google)
AI_IDEA_GENERATION_MODEL="gemini-3.1-flash-lite"
AI_IDEA_OPENAI_MODEL="gpt-4o-mini"
AI_IDEA_ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# Google Search Console / GA4 (optional; metrics sync skips API without keys)
GSC_CLIENT_EMAIL=""
GSC_PRIVATE_KEY=""
GA4_PROPERTY_ID=""
GA4_CLIENT_EMAIL=""
GA4_PRIVATE_KEY=""

# Cron patterns (optional; defaults in TrafficEngineSchedulerService)
METRICS_INGESTION_CRON="0 2 * * *"
PERFORMANCE_EVAL_CRON="0 4 * * *"

# Evaluation thresholds
UNDERPERFORM_CTR_THRESHOLD="0.02"
UNDERPERFORM_POSITION_THRESHOLD="20"
UNDERPERFORM_DAYS_OLD="30"
UNDERPERFORM_MIN_IMPRESSIONS="100"
REWRITE_COOLDOWN_DAYS="14"

# Optional SerpAPI for real related queries (GET /keyword-research/enrich?seed=...)
SERPAPI_API_KEY=""
SERPAPI_TIMEOUT_MS="8000"

# Google Search Console service account JSON (single line) for future GSC pull
GSC_SERVICE_ACCOUNT_JSON=""

# Villa Silyan brand prompts
# Preferred: comma-separated site IDs (e.g. "3,7"). Takes precedence over domain heuristic.
VILLA_SILYAN_SITE_IDS=""
# Legacy: set true to enable for all sites (use VILLA_SILYAN_SITE_IDS instead)
ENABLE_VILLA_SILYAN_PROMPTS="false"

# Originality check thresholds
ORIGINALITY_MAX_OVERLAP="0.25"
ORIGINALITY_COMPARE_LIMIT="20"

# Cloudinary CDN for generated page hero images.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# When set, PageHeroCdnService uploads hero images to Cloudinary on publish and
# stores the secure_url in generatedImageCdnUrl. No local filesystem is used.
CLOUDINARY_URL=""

# Webhook retry (failed publish notifications)
WEBHOOK_RETRY_CRON="*/5 * * * *"
WEBHOOK_RETRY_BASE_MS="60000"
PUBLISH_WEBHOOK_TIMEOUT_MS="5000"

# Telegram ops alerts (AI provider billing/quota failures — never commit real token)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# TELEGRAM_ALERTS_ENABLED="true"
# TELEGRAM_BILLING_ALERT_COOLDOWN_SEC="3600"

# GSC lookback window in days for metrics ingestion (default 28)
GSC_LOOKBACK_DAYS="28"

# Clinic inventory (Google Places discovery — merged into traffic-engine)
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACES_USE_NEW_API="true"
GOOGLE_PLACES_DAILY_QUOTA="1000"
DISCOVERY_GLOBAL_KILL_SWITCH="false"
DISCOVERY_LLM_DISABLED="false"
DISCOVERY_DRY_RUN_DEFAULT="false"
MIN_INTERVIEWS_FOR_LIVE="5"

# Clinic pages are written to the MedCover site by domain. Defaults to medcover.io.
CLINIC_SITE_DOMAIN=medcover.io
# Optional: only needed for external HTTP callers of POST /clinic-inventory/webhook
TRAFFIC_ENGINE_WEBHOOK_SECRET=change_me_in_production

# MedCover production setup
# Run scripts/seed-medcover.sh against Railway to create/update medcover.com,
# seed ContentTemplates and Subjects, and rotate the frontend content API key.
# Store the printed content API key in the Next.js frontend environment, not here.
