{
  "name": "traffic-engine-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build && prisma generate && cp -r dist/src/. dist/",
    "start": "prisma migrate deploy && node dist/main",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "telegram:test": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/test-telegram-alert.ts",
    "test:classifier": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/modules/traffic-engine/observability/error-classifier.service.spec.ts",
    "test:seo-gate": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/modules/traffic-engine/pipeline-v3/seo-gate.utils.spec.ts",
    "test:slug-util": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/modules/traffic-engine/content-api/catalog/slug.util.spec.ts",
    "migrate:medcover-slugs": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/migrate-medcover-slugs.ts",
    "seed:medcover-hubs": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/seed-medcover-hubs.ts",
    "test:medcover-apis": "bash scripts/test-medcover-apis.sh",
    "test:treatment-guard": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/test-treatment-slug-guard.ts",
    "test:page-type-util": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/modules/traffic-engine/content-api/seo/page-type.util.spec.ts",
    "test:entity-resolver": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' src/modules/traffic-engine/content-api/seo/entity-resolver.spec.ts",
    "backfill:guide-entities": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/backfill-guide-entities.ts",
    "backfill:clinic-robots-index": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/backfill-clinic-robots-index.ts"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.4.1",
    "jose": "5.9.6",
    "markdown-it": "^14.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.17.6",
    "@types/sharp": "^0.31.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
