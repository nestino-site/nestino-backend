PORT=3003
DATABASE_URL=postgresql://postgres:password@localhost:5432/clinic_inventory

REDIS_URL=redis://localhost:6379

# Shared with apps/authentication — used to verify admin JWT tokens
JWT_ACCESS_SECRET=change_me_in_production

# -------------------------------------------------------------------
# Discovery pipeline — env-level kill switches (override all DB config)
# -------------------------------------------------------------------
DISCOVERY_GLOBAL_KILL_SWITCH=false
DISCOVERY_LLM_DISABLED=false
DISCOVERY_DRY_RUN_DEFAULT=false
# Set to true for local dev / CI to skip real AI calls
AI_STUB=false

# -------------------------------------------------------------------
# Discovery sources
# -------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=
# Prefer Places API (New) for server-side keys; set false to use legacy Text Search only
GOOGLE_PLACES_USE_NEW_API=true
GOOGLE_PLACES_DAILY_QUOTA=1000

# -------------------------------------------------------------------
# LLM providers (only needed when llm_extract / llm_pricing steps enabled)
# -------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# -------------------------------------------------------------------
# Truth Score
# -------------------------------------------------------------------
MIN_INTERVIEWS_FOR_LIVE=5

# -------------------------------------------------------------------
# Outbound webhooks → traffic-engine-backend
# -------------------------------------------------------------------
TRAFFIC_ENGINE_WEBHOOK_URL=http://localhost:3001/api/v1/clinic-inventory/webhook
TRAFFIC_ENGINE_WEBHOOK_SECRET=change_me_in_production
